create table marks (id int, subject varchar(50), marks int);

select s.id, s.name, s.city, s.age, m.marks, m.subject from Student s  INNER JOIN marks m on s.id = m.id;

select s.id, s.name, s.city, s.age, m.marks, m.subject from Student s  LEFT JOIN marks m on s.id = m.id;

select s.id, s.name, s.city, s.age, m.marks, m.subject from Student s  right Join marks m on s.id = m.id;

select * from Student CROSS JOIN marks;

//SELF JOIN
SELECT a.name, b.name FROM student a, student b WHERE a.city = b.city;

SELECT AVG(age) FROM student;

//SUBQUERIES

//single row subquery
select * from student where age > (select avg(age) from student);

//IN subquery
SELECT * FROM student WHERE id IN (SELECT id FROM marks);

//exists subquery
 select * from student s where EXISTS (select 1 from marks m where s.id = m.id);


//Window Functions -- ROW_NUMBER()
SELECT name, ROW_NUMBER() OVER (ORDER BY age DESC) AS row_num FROM student;

SELECT name, city, age, ROW_NUMBER() OVER (PARTITION BY city ORDER BY age DESC) FROM student;

//Window Functions -- rank()
//give rank of std based on marks
SELECT name, age, RANK() OVER (ORDER BY age DESC) AS rnk FROM student;

//Window Functions -- Dense rank()
SELECT name, age, DENSE_RANK() OVER(ORDER BY age DESC) AS drnk FROM student;

SELECT name, city, age, RANK() OVER (PARTITION BY city ORDER BY age DESC) AS rnk FROM student;

