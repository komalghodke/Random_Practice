CREATE FUNCTION check_adult(a INT)
RETURNS VARCHAR(20)
DETERMINISTIC

BEGIN
    IF a >= 18 THEN
        RETURN 'Adult';
    ELSE
        RETURN 'Minor';
    END IF;
END //

