CREATE TABLE student_log(log_id INT AUTO_INCREMENT PRIMARY KEY, message VARCHAR(100));
	
CREATE TRIGGER trg_after_insert
AFTER INSERT
ON student
FOR EACH ROW
BEGIN
    INSERT INTO student_log(message)
    VALUES(CONCAT('Inserted student: ', NEW.name));
END //
DELIMITER ;

